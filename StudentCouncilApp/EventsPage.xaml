<UserControl x:Class="StudentCouncilApp.EventsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <UserControl.Resources>
        <Style x:Key="FilterButtonStyle" TargetType="RadioButton">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#3498DB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="EventCardTemplate">
            <Border Background="White" 
                    CornerRadius="10" 
                    Margin="0,0,0,15"
                    BorderBrush="{Binding CardBorderColor}"
                    BorderThickness="2"
                    Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="5" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Заголовок и направление -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Text="{Binding Name}" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"
                                   TextWrapping="Wrap"/>
                        <Border Grid.Column="1" 
                                Background="#ECF0F1" 
                                CornerRadius="15" 
                                Padding="8,3">
                            <TextBlock Text="{Binding DirectionName}" 
                                       FontSize="11" 
                                       Foreground="#7F8C8D"/>
                        </Border>
                    </Grid>

                    <!-- Дата и место -->
                    <TextBlock Text="{Binding FormattedDate}" 
                               FontSize="13" 
                               Foreground="#E67E22"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Place}" 
                               FontSize="12" 
                               Foreground="#7F8C8D"
                               Margin="0,0,0,10"/>

                    <!-- Баллы и участники -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🎁" FontSize="12"/>
                        <TextBlock Text="{Binding Scores}" 
                                   FontSize="12" 
                                   FontWeight="Bold"
                                   Foreground="#27AE60"
                                   Margin="3,0,15,0"/>
                        <TextBlock Text="👥" FontSize="12"/>
                        <TextBlock Text="{Binding ParticipantsCount}" 
                                   FontSize="12" 
                                   Foreground="#7F8C8D"
                                   Margin="3,0,0,0"/>
                    </StackPanel>

                    <!-- Кнопка действия -->
                    <Button x:Name="btnAction"
                            Tag="{Binding EventID}"
                            Content="{Binding Status}"
                            Height="35"
                            Width="160"
                            Background="{Binding StatusColor}"
                            Foreground="White"
                            FontWeight="Bold"
                            Cursor="Hand"
                            IsEnabled="{Binding IsActive}"
                            Click="BtnAction_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <!-- Кнопка просмотра участников -->
                    <Button Content="👥 Посмотреть участников"
                            Tag="{Binding EventID}"
                            Height="30"
                            Background="Transparent"
                            Foreground="#3498DB"
                            FontSize="11"
                            Cursor="Hand"
                            BorderThickness="0"
                            Margin="0,5,0,0"
                            Click="BtnViewParticipants_Click"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Margin="0,0,0,15">
            <StackPanel Margin="20">
                <TextBlock Text="План активностей" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Нажимай &quot;Участвую&quot;, чтобы не потеряться" 
                           FontSize="14" 
                           Foreground="#BDC3C7"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Фильтры -->
        <ScrollViewer Grid.Row="1" 
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Margin="15,0,15,15">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="filterAll" 
                             Content="Все" 
                             IsChecked="True"
                             Style="{StaticResource FilterButtonStyle}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="filter1" 
                             Content="🌍 Волонтерство" 
                             Tag="1"
                             Style="{StaticResource FilterButtonStyle}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="filter2" 
                             Content="⚽ Спорт" 
                             Tag="2"
                             Style="{StaticResource FilterButtonStyle}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="filter3" 
                             Content="🔬 Наука" 
                             Tag="3"
                             Style="{StaticResource FilterButtonStyle}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="filter4" 
                             Content="🎮 Киберспорт" 
                             Tag="4"
                             Style="{StaticResource FilterButtonStyle}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="filter5" 
                             Content="📸 Медиа" 
                             Tag="5"
                             Style="{StaticResource FilterButtonStyle}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="filter6" 
                             Content="🎭 Культмасс" 
                             Tag="6"
                             Style="{StaticResource FilterButtonStyle}"
                             Checked="Filter_Checked"/>
                <RadioButton x:Name="filter7" 
                             Content="👥 Тим-лидеры" 
                             Tag="7"
                             Style="{StaticResource FilterButtonStyle}"
                             Checked="Filter_Checked"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Список мероприятий -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EventsList"
                         Margin="20,0,20,20"
                         ItemTemplate="{StaticResource EventCardTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Окно участников -->
        <Border x:Name="participantsOverlay" 
                Background="#80000000" 
                Visibility="Collapsed"
                Grid.RowSpan="3">
            <Border Width="400" 
                    Height="500" 
                    Background="White" 
                    CornerRadius="15"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <Border Grid.Row="0" Background="#2C3E50" CornerRadius="15,15,0,0" Padding="15">
                        <StackPanel>
                            <TextBlock x:Name="participantsEventTitle" 
                                       Text="Участники мероприятия" 
                                       FontSize="16" 
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock x:Name="participantsCount" 
                                       Text="0 человек" 
                                       FontSize="12" 
                                       Foreground="#BDC3C7"/>
                        </StackPanel>
                    </Border>

                    <!-- Список участников -->
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl x:Name="participantsList" Margin="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#ECF0F1" 
                                            BorderThickness="0,0,0,1" 
                                            Padding="10,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FullName}" 
                                                       FontSize="14" 
                                                       FontWeight="Bold"
                                                       Foreground="#2C3E50"/>
                                            <TextBlock Text="{Binding GroupName}" 
                                                       FontSize="11" 
                                                       Foreground="#7F8C8D"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Row="2" 
                            Content="Закрыть" 
                            Height="40"
                            Margin="15"
                            Background="#E74C3C" 
                            Foreground="White"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="CloseParticipants_Click"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>