<Window x:Class="StudentCouncilApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Студенческий совет - Авторизация" 
        Height="450" Width="600" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <TextBlock Text="Студенческий совет" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Основной контент -->
        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Width="350">

            <TextBlock Text="Вход в систему" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <!-- Логин -->
            <TextBlock Text="Логин" 
                       Foreground="#555" 
                       Margin="0,10,0,5"/>
            <TextBox x:Name="txtLogin" 
                     Height="35" 
                     Padding="10" 
                     FontSize="14"
                     BorderBrush="#CCC"
                     BorderThickness="1"/>

            <!-- Пароль -->
            <TextBlock Text="Пароль" 
                       Foreground="#555" 
                       Margin="0,15,0,5"/>
            <PasswordBox x:Name="txtPassword" 
                         Height="35" 
                         Padding="10" 
                         FontSize="14"
                         BorderBrush="#CCC"
                         BorderThickness="1"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,30,0,0">
                <Button x:Name="btnLogin" 
                        Content="Войти" 
                        Width="120" Height="40"
                        Background="#3498DB" 
                        Foreground="White"
                        FontSize="14" 
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,0,10,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnRegister" 
                        Content="Регистрация" 
                        Width="120" Height="40"
                        Background="#95A5A6" 
                        Foreground="White"
                        FontSize="14" 
                        FontWeight="Bold"
                        Cursor="Hand"/>
            </StackPanel>

            <!-- Статус -->
            <TextBlock x:Name="txtStatus" 
                       Text="" 
                       Foreground="Red" 
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>