<UserControl x:Class="StudentCouncilApp.SupervisorEventsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="EventCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопка добавления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="btnAddEvent" 
                    Content="➕ Добавить мероприятие" 
                    Background="#27AE60"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="BtnAddEvent_Click"/>
        </StackPanel>

        <!-- Список мероприятий -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EventsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource EventCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="14" 
                                               FontWeight="Bold"
                                               Foreground="#2C3E50"/>
                                    <TextBlock Text="{Binding DirectionName}" 
                                               FontSize="11" 
                                               Foreground="#7F8C8D"
                                               Margin="0,2,0,5"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="✏️" 
                                            Width="30" Height="30"
                                            Background="#3498DB" 
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Tag="{Binding EventID}"
                                            Click="BtnEditEvent_Click"/>
                                    <Button Content="🗑️" 
                                            Width="30" Height="30"
                                            Background="#E74C3C" 
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Tag="{Binding EventID}"
                                            Margin="5,0,0,0"
                                            Click="BtnDeleteEvent_Click"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           Text="{Binding FormattedDateTime}" 
                                           FontSize="12" 
                                           Foreground="#E67E22"
                                           Margin="0,5,0,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                           Text="{Binding Place}" 
                                           FontSize="12" 
                                           Foreground="#7F8C8D"/>

                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="🎁" FontSize="12"/>
                                    <TextBlock Text="{Binding Scores}" 
                                               FontSize="12" 
                                               FontWeight="Bold"
                                               Foreground="#27AE60"
                                               Margin="3,0,0,0"/>
                                    <TextBlock Text="  👥" FontSize="12" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding ParticipantsCount}" 
                                               FontSize="12" 
                                               Foreground="#7F8C8D"
                                               Margin="3,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Диалог добавления/редактирования мероприятия -->
        <Border x:Name="eventDialog" 
                Background="#80000000" 
                Visibility="Collapsed">
            <Border Width="500" 
                    Background="White" 
                    CornerRadius="15"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel Margin="20">
                    <TextBlock x:Name="dialogTitle" 
                               Text="Добавить мероприятие" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Название:" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtName" Height="35" Padding="10"/>

                    <TextBlock Text="Направление:" Foreground="#7F8C8D" Margin="0,10,0,5"/>
                    <ComboBox x:Name="cmbDirection" Height="35" DisplayMemberPath="Name"/>

                    <TextBlock Text="Дата:" Foreground="#7F8C8D" Margin="0,10,0,5"/>
                    <DatePicker x:Name="dateEvent" Height="35"/>

                    <TextBlock Text="Время:" Foreground="#7F8C8D" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtTime" Height="35" Padding="10" Text="14:00"/>

                    <TextBlock Text="Место:" Foreground="#7F8C8D" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtPlace" Height="35" Padding="10"/>

                    <TextBlock Text="Баллы за участие:" Foreground="#7F8C8D" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtScores" Height="35" Padding="10" Text="10"/>

                    <TextBlock Text="Ожидаемое количество участников:" Foreground="#7F8C8D" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtExpected" Height="35" Padding="10" Text="30"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Отмена" 
                                Height="35" Width="100"
                                Background="#95A5A6" Foreground="White"
                                Cursor="Hand" Margin="0,0,10,0"
                                Click="CancelDialog_Click"/>
                        <Button x:Name="btnSave" 
                                Content="Сохранить" 
                                Height="35" Width="100"
                                Background="#27AE60" Foreground="White"
                                FontWeight="Bold" Cursor="Hand"
                                Click="SaveEvent_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>