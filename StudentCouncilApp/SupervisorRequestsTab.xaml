<UserControl x:Class="StudentCouncilApp.SupervisorRequestsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="RequestCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фильтр по мероприятиям -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Выберите мероприятие:" Foreground="#7F8C8D" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbEventFilter" 
                      Height="35" 
                      DisplayMemberPath="Name"
                      SelectionChanged="CmbEventFilter_SelectionChanged"/>
        </StackPanel>

        <!-- Список заявок -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="RequestsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource RequestCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Студент -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="{Binding StudentName}" 
                                               FontSize="14" 
                                               FontWeight="Bold"
                                               Foreground="#2C3E50"/>
                                    <TextBlock Text="{Binding StudentGroup}" 
                                               FontSize="11" 
                                               Foreground="#7F8C8D"
                                               Margin="0,2,0,5"/>
                                </StackPanel>

                                <!-- Баллы за мероприятие -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="🎁" FontSize="12"/>
                                    <TextBlock Text="{Binding EventScores}" 
                                               FontSize="12" 
                                               FontWeight="Bold"
                                               Foreground="#27AE60"
                                               Margin="3,0,0,0"/>
                                </StackPanel>

                                <!-- Мероприятие -->
                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           Text="{Binding EventName}" 
                                           FontSize="12" 
                                           FontWeight="SemiBold"
                                           Foreground="#3498DB"
                                           Margin="0,0,0,5"/>

                                <!-- Дата и время заявки -->
                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                           Text="{Binding RequestDate}" 
                                           FontSize="11" 
                                           Foreground="#7F8C8D"
                                           Margin="0,0,0,5"/>

                                <!-- Комментарий -->
                                <TextBlock Grid.Row="3" Grid.Column="0" 
                                           Text="{Binding Note}" 
                                           FontSize="11" 
                                           Foreground="#555"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <!-- Кнопки действий -->
                                <StackPanel Grid.Row="1" Grid.RowSpan="3" Grid.Column="1" 
                                            Orientation="Horizontal" 
                                            VerticalAlignment="Center">
                                    <Button Content="✅ Принять" 
                                            Style="{StaticResource ActionButtonStyle}"
                                            Background="#27AE60"
                                            Tag="{Binding RequestID}"
                                            Click="AcceptRequest_Click"/>
                                    <Button Content="❌ Отклонить" 
                                            Style="{StaticResource ActionButtonStyle}"
                                            Background="#E74C3C"
                                            Tag="{Binding RequestID}"
                                            Click="RejectRequest_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Пустое состояние -->
        <TextBlock x:Name="txtEmptyState" 
                   Grid.Row="1"
                   Text="Нет заявок на выбранное мероприятие" 
                   FontSize="14" 
                   Foreground="#7F8C8D"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>