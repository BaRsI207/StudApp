<Window x:Class="StudentCouncilApp.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация нового студента" 
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#F5F5F5">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <TextBlock Text="Регистрация" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Фамилия -->
                <TextBlock Text="Фамилия*" Foreground="#555" Margin="0,10,0,5"/>
                <TextBox x:Name="txtLName" Height="35" Padding="10"/>

                <!-- Имя -->
                <TextBlock Text="Имя*" Foreground="#555" Margin="0,10,0,5"/>
                <TextBox x:Name="txtFName" Height="35" Padding="10"/>

                <!-- Отчество -->
                <TextBlock Text="Отчество" Foreground="#555" Margin="0,10,0,5"/>
                <TextBox x:Name="txtMName" Height="35" Padding="10"/>

                <!-- Email -->
                <TextBlock Text="Email*" Foreground="#555" Margin="0,10,0,5"/>
                <TextBox x:Name="txtEmail" Height="35" Padding="10"/>

                <!-- Телефон -->
                <TextBlock Text="Телефон" Foreground="#555" Margin="0,10,0,5"/>
                <TextBox x:Name="txtPhone" Height="35" Padding="10"/>

                <!-- Логин -->
                <TextBlock Text="Логин*" Foreground="#555" Margin="0,10,0,5"/>
                <TextBox x:Name="txtLogin" Height="35" Padding="10"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль*" Foreground="#555" Margin="0,10,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Padding="10"/>

                <!-- Подтверждение пароля -->
                <TextBlock Text="Подтвердите пароль*" Foreground="#555" Margin="0,10,0,5"/>
                <PasswordBox x:Name="txtConfirmPassword" Height="35" Padding="10"/>

                <!-- Группа (заглушка, потом загрузим из БД) -->
                <TextBlock Text="Группа*" Foreground="#555" Margin="0,10,0,5"/>
                <ComboBox x:Name="cmbGroup" Height="35" DisplayMemberPath="Name"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <Button x:Name="btnRegister" Content="Зарегистрироваться" 
                            Width="180" Height="40"
                            Background="#27AE60" Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            Cursor="Hand" Margin="0,0,10,0"/>

                    <Button x:Name="btnCancel" Content="Отмена" 
                            Width="100" Height="40"
                            Background="#E74C3C" Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            Cursor="Hand"/>
                </StackPanel>

                <TextBlock x:Name="txtStatus" Text="" Foreground="Red" 
                           HorizontalAlignment="Center" Margin="0,15,0,10"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>